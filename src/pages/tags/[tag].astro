---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const uniqueTags = [...new Set(allPosts.map((post) => post.data.tags || []).flat())];

	return uniqueTags.map((tag) => {
		const filteredPosts = allPosts.filter((post) => post.data.tags?.includes(tag));
		return {
			params: { tag },
			props: { posts: filteredPosts },
		};
	});
}

const { tag } = Astro.params;
const { posts } = Astro.props;
---

<Layout title={`Posts tagged with ${tag} | Sven Wasmer`} description={`All blog posts tagged with ${tag}.`}>
	<div style="margin-bottom: 3rem;">
		<a href="/tags" style="font-size: 0.875rem; color: var(--text-muted);">&larr; Back to all tags</a>
		<h1 style="font-size: 3rem; margin-top: 1rem;">Posts tagged with <span style="color: var(--accent);">{tag}</span></h1>
	</div>
	
	<div class="post-list">
		{posts.map((post) => (
			<a href={`/blog/${post.id}`} class="glass-card" style="display: block; color: inherit;">
				<span class="post-meta">{post.data.published.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
				<h3 class="post-title" style="color: #fff; margin-bottom: 0.5rem;">{post.data.title}</h3>
				<p style="color: var(--text-muted); margin: 0;">{post.data.description}</p>
			</a>
		))}
	</div>
</Layout>
