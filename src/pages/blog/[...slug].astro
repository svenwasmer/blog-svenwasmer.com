---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map(post => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const toc: any[] = [];
if (headings) {
	headings.filter((h: any) => h.depth > 1 && h.depth < 4).forEach((h: any) => {
		if (h.depth === 2) {
			toc.push({ ...h, children: [] });
		} else if (h.depth === 3 && toc.length > 0) {
			toc[toc.length - 1].children.push(h);
		}
	});
}
---

<Layout title={`${post.data.title} | Sven Wasmer`} description={post.data.description}>
	<article class="prose" style="max-width: 800px; margin: 0 auto;">
		<header style="margin-bottom: 3rem; text-align: center;">
			<span class="post-meta" style="font-family: 'Outfit', sans-serif; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent);">{post.data.published.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
			<h1 style="font-size: 3rem; margin-top: 1rem; margin-bottom: 1.5rem; line-height: 1.1;">{post.data.title}</h1>
			{post.data.tags && post.data.tags.length > 0 && (
				<div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
					{post.data.tags.map((tag: string) => (
						<a href={`/tags/${tag}`} style="background: rgba(255,255,255,0.05); border: 1px solid var(--card-border); padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.875rem; color: var(--text-color); transition: all 0.2s ease; display: inline-block;">{tag}</a>
					))}
				</div>
			)}
		</header>

		<div style="position: relative;">
			{post.data.image && typeof post.data.image === 'object' && (
				<Image src={post.data.image} alt={post.data.title} width={1024} height={576} style="width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; border-radius: 1rem; margin-bottom: 3rem; box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);" />
			)}
			{post.data.image && typeof post.data.image === 'string' && (
				<img src={post.data.image} alt={post.data.title} style="width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; border-radius: 1rem; margin-bottom: 3rem; box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);" />
			)}

			{post.data.toc && headings && headings.length > 0 && (
			<aside class="post-sidebar">
				<nav class="toc">
					<h2 style="margin-top: 0; margin-bottom: 1.5rem; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted);">Table of Contents</h2>
					<ul style="list-style: none; padding: 0; margin: 0;">
						{toc.map((h2: any) => (
							<li class="toc-item">
								<a href={`#${h2.slug}`} class="toc-link">
									{h2.text}
								</a>
								{h2.children.length > 0 && (
									<ul class="toc-sublist" style="display: none; list-style: none; padding-left: 1rem; margin-top: 0.5rem; margin-bottom: 0; border-left: 1px solid rgba(255,255,255,0.1); margin-left: 0.5rem;">
										{h2.children.map((h3: any) => (
											<li style="margin-bottom: 0.5rem;">
												<a href={`#${h3.slug}`} class="toc-link" style="font-size: 0.85rem;">
													{h3.text}
												</a>
											</li>
										))}
									</ul>
								)}
							</li>
						))}
					</ul>
				</nav>
			</aside>
		)}

			<div class="content-body" style="font-size: 1.125rem; line-height: 1.8;">
				<Content />
			</div>
		</div>
	</article>
</Layout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const headingId = entry.target.id;
					document.querySelectorAll('.toc-link').forEach((link) => {
						link.classList.remove('active');
					});
					document.querySelectorAll('.toc-sublist').forEach((list: any) => {
						list.style.display = 'none';
					});
					
					const activeLink = document.querySelector(`.toc-link[href="#${headingId}"]`);
					if (activeLink) {
						activeLink.classList.add('active');
						const parentItem = activeLink.closest('.toc-item');
						if (parentItem) {
							const sublist = parentItem.querySelector('.toc-sublist') as HTMLElement;
							if (sublist) sublist.style.display = 'block';
						}
					}
				}
			});
		}, { rootMargin: '0px 0px -70% 0px' });

		document.querySelectorAll('.content-body h2, .content-body h3').forEach((heading) => {
			observer.observe(heading);
		});
	});
</script>

<style>
	.toc-item {
		margin-bottom: 0.85rem;
		line-height: 1.5;
	}
	.toc-link {
		color: var(--text-muted);
		opacity: 0.7;
		font-size: 0.95rem;
		text-decoration: none;
		transition: all 0.2s ease;
		display: inline-block;
	}
	.toc-link:hover {
		color: #fff;
		opacity: 1;
	}
	.toc-link.active {
		color: var(--accent);
		opacity: 1;
		font-weight: 500;
		transform: translateX(4px);
	}
	.toc {
		display: block;
		margin: 0;
		padding: 0;
		border-bottom: none;
	}
	
	/* Mobile styling: TOC sits above content */
	.post-sidebar {
		margin-bottom: 3rem;
		background: rgba(255,255,255,0.02);
		padding: 1.5rem;
		border-radius: 1rem;
		border: 1px solid var(--card-border);
	}

	/* Desktop styling: TOC breaks out to the far left and floats */
	@media (min-width: 1300px) {
		.post-sidebar {
			position: absolute;
			top: 0;
			right: 100%;
			margin-right: 4rem;
			width: 260px;
			height: 100%;
			z-index: 10;
			background: none;
			padding: 0;
			border: none;
			margin-bottom: 0;
		}
		.toc {
			position: sticky;
			top: 6rem;
		}
	}
</style>
