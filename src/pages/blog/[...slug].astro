---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map(post => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<Layout title={`${post.data.title} | Sven Wasmer`} description={post.data.description}>
	<article class="prose">
		<header style="margin-bottom: 3rem; text-align: center;">
			<span class="post-meta" style="font-family: 'Outfit', sans-serif; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent);">{post.data.published.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
			<h1 style="font-size: 3rem; margin-top: 1rem; margin-bottom: 1.5rem; line-height: 1.1;">{post.data.title}</h1>
			{post.data.tags && post.data.tags.length > 0 && (
				<div style="display: flex; gap: 0.5rem; justify-content: center; flex-wrap: wrap;">
					{post.data.tags.map((tag: string) => (
						<a href={`/tags/${tag}`} style="background: rgba(255,255,255,0.05); border: 1px solid var(--card-border); padding: 0.25rem 0.75rem; border-radius: 99px; font-size: 0.875rem; color: var(--text-color); transition: all 0.2s ease; display: inline-block;">{tag}</a>
					))}
				</div>
			)}
		</header>

		{post.data.image && typeof post.data.image === 'object' && (
			<Image src={post.data.image} alt={post.data.title} width={1024} height={576} style="width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; border-radius: 1rem; margin-bottom: 3rem; box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);" />
		)}
		{post.data.image && typeof post.data.image === 'string' && (
			<img src={post.data.image} alt={post.data.title} style="width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; border-radius: 1rem; margin-bottom: 3rem; box-shadow: 0 20px 40px -10px rgba(0,0,0,0.5);" />
		)}

		<div class="post-layout">
			<div class="post-content-wrapper">
				<div class="content-body" style="font-size: 1.125rem; line-height: 1.8;">
					<Content />
				</div>
			</div>

			{post.data.toc && headings && headings.length > 0 && (
				<aside class="post-sidebar">
					<nav class="toc" style="background: rgba(255,255,255,0.03); border: 1px solid var(--card-border); padding: 1.5rem; border-radius: 1rem;">
						<h2 style="margin-top: 0; margin-bottom: 1rem; font-size: 1.25rem;">Table of Contents</h2>
						<ul style="list-style: none; padding: 0; margin: 0;">
							{headings.filter((h: any) => h.depth > 1 && h.depth < 4).map((heading: any) => (
								<li style={`margin-left: ${(heading.depth - 2) * 1.25}rem; margin-bottom: 0.5rem; line-height: 1.4;`}>
									<a href={`#${heading.slug}`} class="toc-link">
										{heading.text}
									</a>
								</li>
							))}
						</ul>
					</nav>
				</aside>
			)}
		</div>
	</article>
</Layout>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const observer = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					const headingId = entry.target.id;
					document.querySelectorAll('.toc-link').forEach((link) => {
						link.classList.remove('active');
					});
					const activeLink = document.querySelector(`.toc-link[href="#${headingId}"]`);
					if (activeLink) activeLink.classList.add('active');
				}
			});
		}, { rootMargin: '0px 0px -70% 0px' });

		document.querySelectorAll('.post-content-wrapper h2, .post-content-wrapper h3').forEach((heading) => {
			observer.observe(heading);
		});
	});
</script>

<style>
	.toc-link {
		color: var(--text-muted);
		opacity: 0.8;
		font-size: 0.95rem;
		text-decoration: none;
		transition: all 0.2s ease;
		display: inline-block;
	}
	.toc-link:hover {
		color: #fff;
		opacity: 1;
	}
	.toc-link.active {
		color: var(--accent);
		opacity: 1;
		font-weight: 600;
		transform: translateX(4px);
	}
	.toc {
		display: block;
		margin: 0;
		padding: 0;
		border-bottom: none;
	}
	.post-layout {
		display: flex;
		flex-direction: column-reverse;
		gap: 2rem;
	}
	@media (min-width: 1024px) {
		.post-layout {
			display: grid;
			grid-template-columns: 1fr 280px;
			gap: 4rem;
			align-items: start;
		}
		.post-content-wrapper {
			grid-column: 1;
			min-width: 0;
		}
		.post-sidebar {
			grid-column: 2;
			position: sticky;
			top: 2rem;
		}
	}
</style>
