---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => {
	return import.meta.env.PROD ? data.draft !== true : true;
})).sort(
	(a, b) => b.data.published.valueOf() - a.data.published.valueOf()
).slice(0, 3);
---

<Layout title="Sven Wasmer | Developer & Writer">
	<section style="margin-bottom: 4rem;">
		<h1 style="font-size: 3.5rem; margin-bottom: 1rem; letter-spacing: -0.05em; background: linear-gradient(to right, #fff, #94a3b8); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Minimal. Fast. <br/> Modern.</h1>
		<p style="font-size: 1.25rem; color: var(--text-muted); max-width: 600px;">
			I am a developer who loves building things and writing about them. Welcome to my digital garden where I share my thoughts, guides, and experiences.
		</p>
	</section>

	<section>
		<h2 style="margin-bottom: 2rem; font-size: 2rem;">Latest Posts</h2>
		<div class="post-list">
			{posts.map((post) => (
				<a href={`/blog/${post.id}`} class="glass-card" style="display: block; color: inherit;">
					<span class="post-meta">{post.data.published.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
					<h3 class="post-title" style="color: #fff; margin-bottom: 0.5rem;">{post.data.title}</h3>
					<p style="color: var(--text-muted); margin: 0;">{post.data.description}</p>
				</a>
			))}
		</div>
		<div style="margin-top: 3rem; text-align: center;">
			<a href="/blog" style="font-family: 'Outfit', sans-serif; font-weight: 600; font-size: 1.125rem;">View all posts &rarr;</a>
		</div>
	</section>
</Layout>
